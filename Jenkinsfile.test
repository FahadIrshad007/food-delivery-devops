pipeline {
    agent any
    
    environment {
        // These will be injected from Jenkins credentials
        MONGO_URL = credentials('mongo-url')
        JWT_SECRET = credentials('jwt-secret')
        SALT = '10'
        DOCKER_REGISTRY = 'your-dockerhub-username'
        APP_NAME = 'food-delivery-app'
        GIT_COMMITTER_EMAIL = ''
    }
    
    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    sh "git config --global --add safe.directory ${env.WORKSPACE}"
                    env.GIT_COMMITTER_EMAIL = sh(
                        script: "git log -1 --pretty=format:'%ae'",
                        returnStdout: true
                    ).trim()
                    echo "Committer Email: ${env.GIT_COMMITTER_EMAIL}"
                }
            }
        }
        
        stage('Build & Deploy Application') {
            steps {
                script {
                    // Create .env file for backend from Jenkins credentials
                    sh '''
                        echo "MONGO_URL=${MONGO_URL}" > backend/.env
                        echo "JWT_SECRET=${JWT_SECRET}" >> backend/.env
                        echo "SALT=${SALT}" >> backend/.env
                        echo "STRIPE_SECRET_KEY=sk_test_placeholder" >> backend/.env
                    '''
                    
                    // Build and start services
                    sh 'docker-compose -f docker-compose.yml build'
                    sh 'docker-compose -f docker-compose.yml up -d'
                    
                    // Wait for services
                    sh 'sleep 15'
                    sh 'docker-compose ps'
                    
                    // Verify backend is running
                    sh 'curl -f http://localhost:4000/ || echo "Backend not ready yet"'
                }
            }
        }

        stage('Test') {
            agent {
                docker {
                    image 'markhobson/maven-chrome'
                    args '-u root:root -v /var/lib/jenkins/.m2:/root/.m2 --network host'
                }
            }
            steps {
                script {
                    // Wait for app to be ready
                    sh 'sleep 10'
                    
                    // Run tests pointing to deployed services
                    sh '''
                        mvn -f selenium-test-project/pom.xml test \
                        -Dapp.url=http://localhost:80 \
                        -Dapi.url=http://localhost:4000
                    '''
                }
            }
        }
        
        stage('Publish Test Results') {
            steps {
                junit 'selenium-test-project/target/surefire-reports/*.xml'
                publishHTML(target: [
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'selenium-test-project/target/surefire-reports',
                    reportFiles: 'index.html',
                    reportName: 'Test Report'
                ])
            }
        }
        
        stage('Cleanup Deployment') {
            steps {
                script {
                    sh 'docker-compose -f docker-compose.yml down'
                    // Remove .env file for security
                    sh 'rm -f backend/.env'
                    echo 'Containerized deployment brought down successfully'
                }
            }
        }
    }

    post {
        always {
            script {
                def testResults = parseTestResults()
                
                emailext(
                    subject: "${env.JOB_NAME} - Build #${env.BUILD_NUMBER} - ${currentBuild.result ?: 'UNKNOWN'}",
                    body: """
                        <html>
                        <body>
                            <h2>Build Report: ${env.JOB_NAME} #${env.BUILD_NUMBER}</h2>
                            <p><strong>Status:</strong> ${currentBuild.result ?: 'In Progress'}</p>
                            <p><strong>Triggered by:</strong> ${env.GIT_COMMITTER_EMAIL}</p>
                            <p><strong>Commit:</strong> ${env.GIT_COMMIT}</p>
                            
                            <h3>Test Summary</h3>
                            <ul>
                                <li>Total Tests: ${testResults.total}</li>
                                <li>Passed: ${testResults.passed}</li>
                                <li>Failed: ${testResults.failed}</li>
                                <li>Skipped: ${testResults.skipped}</li>
                            </ul>
                            
                            <h3>Details</h3>
                            <pre>${testResults.details}</pre>
                            
                            <p>View full results: <a href="${env.BUILD_URL}">Build URL</a></p>
                        </body>
                        </html>
                    """,
                    to: "${env.GIT_COMMITTER_EMAIL}",
                    from: 'jenkins@your-domain.com',
                    replyTo: 'jenkins@your-domain.com',
                    mimeType: 'text/html'
                )
            }
        }
        
        failure {
            script {
                emailext(
                    subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: "Build failed. Check logs at: ${env.BUILD_URL}console",
                    to: "${env.GIT_COMMITTER_EMAIL}"
                )
            }
        }
    }
}

def parseTestResults() {
    def result = [total: 0, passed: 0, failed: 0, skipped: 0, details: ""]
    
    try {
        def reports = findFiles(glob: 'selenium-test-project/target/surefire-reports/*.xml')
        
        reports.each { report ->
            def content = readFile(report.path)
            def testsuite = new XmlSlurper().parseText(content)
            
            result.total += testsuite.@tests.toInteger()
            result.failed += testsuite.@failures.toInteger() + testsuite.@errors.toInteger()
            result.skipped += testsuite.@skipped.toInteger()
            
            testsuite.testcase.each { testcase ->
                def name = testcase.@name
                def status = "PASSED"
                if (testcase.failure.size() > 0) {
                    status = "FAILED"
                    result.details += "${name} - FAILED\n"
                } else if (testcase.skipped.size() > 0) {
                    status = "SKIPPED"
                    result.details += "${name} - SKIPPED\n"
                } else {
                    result.passed++
                    result.details += "${name} - PASSED\n"
                }
            }
        }
    } catch (Exception e) {
        result.details = "Error parsing results: ${e.getMessage()}"
    }
    
    return result
}